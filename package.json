{
  "name": "@vap/react-native-wheel",
  "version": "1.1.4",
  "description": "High-performance React Native Wheel of Fortune spinner with Reanimated 60fps animations, SVG & Skia renderers, weighted probability, and controlled winner mode",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native-wheel-source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-wheel-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "release": "release-it --only-version"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "web",
    "wheel",
    "spinner",
    "fortune",
    "wheel-of-fortune",
    "fortune-wheel",
    "prize-wheel",
    "spin",
    "spin-wheel",
    "spinning-wheel",
    "picker",
    "random-picker",
    "reanimated",
    "react-native-reanimated",
    "svg",
    "skia",
    "animation",
    "game",
    "lottery"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vapnguyen24/react-native-wheel.git"
  },
  "author": "vapnguyen24 <vinhnt.work@gmail.com> (https://github.com/vapnguyen24)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vapnguyen24/react-native-wheel/issues"
  },
  "homepage": "https://github.com/vapnguyen24/react-native-wheel#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^29.7.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@react-native/metro-config": "^0.86.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@shopify/react-native-skia": "2.6.6",
    "@testing-library/react-native": "^14.0.0",
    "@types/react": "^19.2.0",
    "commitlint": "^21.0.2",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.6",
    "hermes-eslint": "^0.36.1",
    "jest": "^29.7.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.43.0",
    "react-native-gesture-handler": "3.0.2",
    "react-native-reanimated": "4.4.1",
    "react-native-svg": "15.15.5",
    "react-native-worklets": "0.9.2",
    "react-test-renderer": "19.2.0",
    "release-it": "^20.2.0",
    "test-renderer": "^1.2.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=2.0.0",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": ">=3.0.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-svg": ">=15.0.0",
    "react-native-worklets": ">=0.9.0"
  },
  "peerDependenciesMeta": {
    "@shopify/react-native-skia": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "testEnvironmentOptions": {
      "customExportConditions": [
        "require",
        "react-native",
        "react-native-wheel-source"
      ]
    },
    "testPathIgnorePatterns": [
      "<rootDir>/src/__tests__/__mocks__/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|react-native-reanimated)/)"
    ],
    "moduleNameMapper": {
      "^react-native-reanimated$": "<rootDir>/node_modules/react-native-reanimated/mock.js",
      "^react-native-worklets$": "<rootDir>/src/__tests__/__mocks__/react-native-worklets.js",
      "^react-native-svg$": "<rootDir>/src/__tests__/__mocks__/react-native-svg.js",
      "^react-native-gesture-handler$": "<rootDir>/src/__tests__/__mocks__/react-native-gesture-handler.js",
      "^@shopify/react-native-skia$": "<rootDir>/src/__tests__/__mocks__/@shopify/react-native-skia.js"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/__tests__/**",
      "!src/types.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 90,
        "functions": 90,
        "branches": 85
      }
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "conventionalcommits",
          "types": [
            {
              "type": "feat",
              "section": "Added"
            },
            {
              "type": "fix",
              "section": "Fixed"
            },
            {
              "type": "perf",
              "section": "Changed"
            },
            {
              "type": "refactor",
              "section": "Changed"
            },
            {
              "type": "docs",
              "section": "Changed"
            },
            {
              "type": "chore",
              "hidden": true
            },
            {
              "type": "style",
              "hidden": true
            },
            {
              "type": "test",
              "hidden": true
            },
            {
              "type": "build",
              "hidden": true
            },
            {
              "type": "ci",
              "hidden": true
            }
          ]
        },
        "header": "# Changelog",
        "infile": "CHANGELOG.md"
      }
    }
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.63.0"
  }
}
